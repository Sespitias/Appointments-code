import google.auth
from google.cloud import bigquery

creds, detected_project = google.auth.default()
print("=== google.auth.default() ===")
print("Proyecto detectado:", detected_project)
print("Tipo de credencial:", type(creds).__name__)

if hasattr(creds, "service_account_email"):
    print("Service account email:", creds.service_account_email)
else:
    print("No es service account; probablemente son credenciales de usuario OAuth.")

client = bigquery.Client(project="weekly-revenue-integration", credentials=creds)
print("=== BigQuery Client ===")
print("Proyecto cliente:", client.project)
